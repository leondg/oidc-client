{
    "name": "leondg/oidc-client",
    "license": "MIT",
    "authors": [
        {
            "name": "Léon de Groot",
            "email": "leon90@outlook.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Leondg\\Oidc\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Leondg\\Oidc\\Client\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^7.4 || ^8.0",
        "league/oauth2-client": "^2.0",
        "psr/simple-cache": "^1.0 || ^2.0 || ^3.0",
        "symfony/serializer": "^5.0 || ^6.0 || ^7.0",
        "symfony/property-access": "^5.0 || ^6.0 || ^7.0",
        "firebase/php-jwt": "^6.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyze",
        "phpcs": "php-cs-fixer fix --dry-run --diff"
    },
    "config": {
        "audit": {
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys"
            ]
        }
    }
}
